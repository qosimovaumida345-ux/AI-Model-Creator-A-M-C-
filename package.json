{
  "name": "ai-model-creator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI Model Creator (AMC)",
  "author": "AMC Team",
  "license": "MIT",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
