    "@react-three/drei": "^9.117.0",
    "framer-motion": "^11.11.17",
    "gsap": "^3.12.5",
    "zustand": "^5.0.1",
    "lucide-react": "^0.460.0",
    "axios": "^1.7.7",
    "uuid": "^10.0.0",
    "@capacitor/core": "^6.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
